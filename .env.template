# Site URL (used in build metadata and sitemap)
SITE=http://localhost

# Base path for GitHub Pages deployment (leave empty for root or local dev)
# For GitHub Pages: BASE_PATH=/your-repo-name/
BASE_PATH=

# GitHub repo for Sveltia CMS backend (auto-detected from git remote or GITHUB_REPOSITORY)
# Only set manually if auto-detection fails
# REPO=your-org/your-repo

# Sveltia CMS auth proxy URL (leave empty if not using GitHub auth)
# AUTH_BASE_URL= (uncomment when using auth proxy)

# Branch for Sveltia CMS (auto-detected from git or GITHUB_REF_NAME; defaults to 'main')
# BRANCH=preview
